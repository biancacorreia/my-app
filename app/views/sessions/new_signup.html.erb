<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">Create Account</h1>
    <p class="auth-subtitle">Join Scentfolio to start tracking your fragrances</p>

    <% if @user&.errors&.any? %>
      <div class="auth-errors">
        <% @user.errors.full_messages.each do |msg| %>
          <p><%=  msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: User.new, url: sign_up_path, class: "auth-form" do |f| %>
      <div class="form-group">
        <%= f.label :name, "Full Name" %>
        <%= f.text_field :name, placeholder: "Your name", autocomplete: "name", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, placeholder: "you@example.com", autocomplete: "email", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, placeholder: "At least 8 characters", autocomplete: "new-password", required: true, minlength: 8 %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation, placeholder: "Repeat your password", autocomplete: "new-password", required: true %>
      </div>

      <%= f.submit "Create Account", class: "auth-submit" %>
    <% end %>

    <p class="auth-footer">Already have an account? <%= link_to "Log in", log_in_path, class: "auth-link" %></p>
  </div>
</div>
