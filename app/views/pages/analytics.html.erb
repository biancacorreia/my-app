<div class="page-header">
  <div>
    <h1 class="page-title">Analytics</h1>
    <p class="page-subtitle">Your fragrance insights</p>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-content">
      <p class="stat-label">Total Entries</p>
      <p class="stat-value"><%= @total_entries %></p>
    </div>
    <div class="stat-icon">✦</div>
  </div>

  <div class="stat-card">
    <div class="stat-content">
      <p class="stat-label">Avg Strength</p>
      <p class="stat-value"><%= @avg_strength %></p>
    </div>
    <div class="stat-icon">↗</div>
  </div>

  <div class="stat-card">
    <div class="stat-content">
      <p class="stat-label">Occasions Tracked</p>
      <p class="stat-value"><%= @occasions.keys.count %></p>
    </div>
    <div class="stat-icon">📅</div>
  </div>
</div>

<% if @occasions.any? %>
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">Entries by Occasion</h2>
    </div>
    <div class="analytics-list">
      <% @occasions.sort_by { |_, v| -v }.each do |occasion, count| %>
        <div class="analytics-row">
          <span class="analytics-label"><%= occasion %></span>
          <div class="analytics-bar-wrap">
            <div class="analytics-bar" style="width: <%= (count.to_f / @total_entries * 100).round %>%"></div>
          </div>
          <span class="analytics-count"><%= count %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h2 class="card-title">Avg Strength by Occasion</h2>
    </div>
    <div class="analytics-list">
      <% @strength_by_occasion.sort_by { |_, v| -v }.each do |occasion, avg| %>
        <div class="analytics-row">
          <span class="analytics-label"><%= occasion %></span>
          <div class="analytics-bar-wrap">
            <div class="analytics-bar" style="width: <%= (avg / 10 * 100).round %>%"></div>
          </div>
          <span class="analytics-count"><%= avg %>/10</span>
        </div>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="card">
    <div class="empty-state">
      <p>No data yet. <%= link_to "Add some entries!", new_entry_path %> to see your analytics.</p>
    </div>
  </div>
<% end %>
