<div class="landing-hero">
  <div class="hero-content">
    <h1 class="hero-title">Scentfolio</h1>
    <p class="hero-subtitle">Track, discover, and cherish your fragrance journey</p>
    <p class="hero-description">Keep detailed records of every fragrance you wear. Log strength, occasion, and personal notes to build your unique scent collection.</p>
    <div class="hero-actions">
      <%= link_to "Create Your Account", sign_up_path, class: "btn btn-hero-primary" %>
      <%= link_to "Log In", log_in_path, class: "btn btn-hero-secondary" %>
    </div>
  </div>
</div>

<div class="landing-features">
  <div class="feature-card">
    <div class="feature-icon">📝</div>
    <h3 class="feature-title">Log Fragrances</h3>
    <p class="feature-description">Record every fragrance with notes, strength level, and occasion</p>
  </div>

  <div class="feature-card">
    <div class="feature-icon">📊</div>
    <h3 class="feature-title">Analyze Trends</h3>
    <p class="feature-description">Discover patterns in your fragrance preferences and habits</p>
  </div>

  <div class="feature-card">
    <div class="feature-icon">✦</div>
    <h3 class="feature-title">Build Your Collection</h3>
    <p class="feature-description">Keep track of all your fragrances in one beautiful place</p>
  </div>
</div>
