<%= form_with model: entry, class: "entry-form" do |f| %>

  <% if entry.errors.any? %>
    <div class="form-errors">
      <% entry.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :fragrance_name, "Fragrance Name", class: "form-label" %>
      <%= f.text_field :fragrance_name, class: "form-input", placeholder: "e.g. Black Orchid" %>
    </div>

    <div class="form-group">
      <%= f.label :brand, "Brand", class: "form-label" %>
      <%= f.text_field :brand, class: "form-input", placeholder: "e.g. Tom Ford" %>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :occasion, "Occasion", class: "form-label" %>
      <%= f.select :occasion, Entry::OCCASIONS,
          { include_blank: "Select occasion..." },
          class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :worn_on, "Date Worn", class: "form-label" %>
      <%= f.date_field :worn_on, class: "form-input" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :strength, "Strength (1-10)", class: "form-label" %>
    <div class="strength-picker">
      <% (1..10).each do |n| %>
        <%= f.radio_button :strength, n, id: "strength_#{n}" %>
        <%= f.label :strength, n, for: "strength_#{n}", class: "strength-btn" %>
      <% end %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :notes, "Notes", class: "form-label" %>
    <%= f.text_area :notes, class: "form-input form-textarea",
        placeholder: "How did it smell? Any memories it evoked?" %>
  </div>

  <div class="form-actions">
    <%= link_to "Cancel", root_path, class: "btn btn-outline" %>
    <%= f.submit entry.new_record? ? "Save Entry" : "Update Entry",
        class: "btn btn-primary" %>
  </div>

<% end %>
