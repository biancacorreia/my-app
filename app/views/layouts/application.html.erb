<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scentfolio</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-brand">
        <span class="brand-name">Scentfolio</span>
      </div>
      <div class="nav-links">
        <%= link_to "Home", root_path, class: "nav-link #{current_page?(root_path) ? 'active' : ''}" %>
        <%= link_to "+ Add Entry", new_entry_path, class: "nav-link #{current_page?(new_entry_path) ? 'active' : ''}" %>
        <%= link_to "History", entries_path, class: "nav-link #{current_page?(entries_path) ? 'active' : ''}" %>
        <%= link_to "Analytics", analytics_path, class: "nav-link #{current_page?(analytics_path) ? 'active' : ''}" %>
        <span class="nav-link settings-icon">⚙</span>
      </div>
    </nav>

    <% if notice %>
      <div class="flash flash-notice"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="flash flash-alert"><%= alert %></div>
    <% end %>

    <main class="main-content">
      <%= yield %>
    </main>
  </body>
</html>
